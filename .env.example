DISCORD_TOKEN=

# Persona: personal (dev/intimate style) | public (fork-friendly). See mai/personality.py.
# MAI_PERSONA=personal

# Logging: DEBUG | INFO | WARNING | ERROR (default INFO)
# LOG_LEVEL=INFO

# Comma-separated guild channel snowflakes; bot only replies there. Omit = all guild channels.
# DISCORD_ALLOWED_CHANNEL_IDS=123456789012345678,987654321098765432
# Private / group DMs (guild is None). false = never reply in DMs.
# DISCORD_ALLOW_DMS=true

# Optional (defaults are in mai/config.py)
# LLM provider: lmstudio (default) | openai_compatible
# LLM_PROVIDER=lmstudio
# Generic chat settings (override LMSTUDIO_* if both are set — LMSTUDIO_* still works alone)
# LLM_API_URL=http://localhost:1234/api/v1/chat
# LLM_MODEL=l3-8b-stheno-v3.2-iq-imatrix
# LLM_USE_SYSTEM_PROMPT=true
# LLM_MAX_OUTPUT_TOKENS=720
# LLM_REPEAT_PENALTY=1.08
# LLM_TEMPERATURE=0.8
# For openai_compatible: full URL to /v1/chat/completions; optional Bearer:
# LLM_API_URL=http://127.0.0.1:11434/v1/chat/completions
# LLM_API_KEY=
# Legacy LM Studio-only names (still supported if LLM_* unset)
# LMSTUDIO_API_URL=http://localhost:1234/api/v1/chat
# LMSTUDIO_MODEL=l3-8b-stheno-v3.2-iq-imatrix
# LMSTUDIO_USE_SYSTEM_PROMPT=true
# LMSTUDIO_MAX_OUTPUT_TOKENS=720
# LMSTUDIO_REPEAT_PENALTY=1.08
# LMSTUDIO_TEMPERATURE=0.8
# Set true to trim rare “double speech” artifacts in one message (usually unnecessary if one bot runs)
# REPLY_SANITIZE=false
# VAULT_PATH=/mnt/d/Vaults/CafeCovenVault/Coven/Agents/Mai
# MAX_INTERACTIONS=10
# MAX_FACTS_LEARNED=80
# REQUEST_TIMEOUT_S=120
# When chat completions fail (LM Studio down, wrong URL, timeout), Mai still saves
# memory/state using this text as her reply. Override to match her voice.
# CHAT_OFFLINE_REPLY=I'm having trouble reaching the model right now—I'm still here. Try again in a moment?
# Emotion: fast | hybrid | llm  (hybrid = LM Studio on “heavy” turns only)
# EMOTION_ANALYSIS_MODE=hybrid
# How fast valence/arousal move toward new readings (0–1)
# EMOTION_STATE_BLEND=0.4
# MAX_TRUST_SHIFT_PER_TURN= 0.15
# MAX_BOND_SHIFT_PER_TURN= 0.12
# MAX_FAMILIARITY_SHIFT_PER_TURN= 0.10
# HARSH_MESSAGE_TRUST_PENALTY= -0.10
# HARSH_MESSAGE_BOND_PENALTY= -0.08